# ===============================
# Railway Environment Variables
# ===============================

# Server Configuration
PORT=3001
NODE_ENV=production

# Database Configuration (Replace with Railway MySQL credentials)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=medconnect
DB_PORT=3306

# Authentication
# Must be at least 32 characters for HS256 algorithm
JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_32_bytes_long

# CORS Configuration
# Comma-separated list of allowed origins
FRONTEND_ORIGIN=https://your-frontend-domain.up.railway.app,http://localhost:5174

# AI Agent (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
